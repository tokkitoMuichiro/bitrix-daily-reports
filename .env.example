# Входящий вебхук Битрикс24 (Разработчикам → Другое → Входящий вебхук)
# Права: task, tasks, disk (+ imbot, im — когда подключаете чат-бота)
BITRIX_WEBHOOK_URL=https://YOUR_PORTAL.bitrix24.ru/rest/1/xxxxxxxx/

# Портал, с которого разрешён вход (локальное приложение)
BITRIX_PORTAL_DOMAIN=ammir.bitrix24.ru

# 1 = только сотрудники через локальное приложение Битрикс (AUTH_ID)
# 0 = открытый доступ (только для локальной разработки / демо)
# Если не задано: при MOCK_BITRIX=1 → выкл, иначе → вкл
REQUIRE_BITRIX_AUTH=1

# Публичный URL приложения (для ссылки в боте), без слэша в конце
APP_PUBLIC_URL=https://your-server.example.com

# Порт локального сервера
PORT=3000

# 1 = демо без Битрикс (отчёты в data/mock-disk/)
# Для боя: MOCK_BITRIX=0 и реальный BITRIX_WEBHOOK_URL
MOCK_BITRIX=1

# ID папки «Ежедневные отчёты» на Диске (если пусто — создастся на общем Диске по имени ниже)
DISK_FOLDER_ID=

# Имя корневой папки отчётов на Диске (если DISK_FOLDER_ID пуст)
# На портале ammir часто: «Ежедневные отчеты» (буква е, не ё)
DISK_REPORTS_FOLDER_NAME=Ежедневные отчеты

# Также дублировать отчёт комментарием к задаче (1/0)
SAVE_TASK_COMMENT=1
